# Copia a .env en la raíz para docker compose
#
# Base de datos: Supabase. Dashboard → Connect → Session pooler. Prefijo asyncpg:
#   postgresql+asyncpg://postgres.[REF]:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
#   (el host exacto lo indica Connect; a veces es aws-1-REGION...)
# Codifica caracteres especiales en la contraseña en la URL (p. ej. @ → %40, * → %2A).
# Si SSL falla (antivirus/proxy): DATABASE_SSL_VERIFY=false
DATABASE_URL=
INTERNAL_API_KEY=dev-internal-key
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_SIGNATURE=false
WEBHOOK_BASE_URL=http://localhost:8000
OPENAI_API_KEY=
# Puerto en el HOST donde publica Compose el panel (contenedor sigue en 3000).
WEB_PUBLISH_PORT=3001
# Debe listar el origen real del panel en el navegador (incluye puerto).
CORS_ORIGINS=http://localhost:3001

# Docker Compose incluye Redis; la API usa REDIS_URL por defecto redis://redis:6379/0. Vacío = límite en memoria.
REDIS_URL=redis://redis:6379/0
LOG_JSON=false
LOG_LEVEL=INFO
GIT_COMMIT=local
